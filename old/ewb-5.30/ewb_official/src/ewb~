     {  $res=$res. substr($code, 0, 1); $code=substr($code, 1); }
    }
    while(($code ne "") && (substr($code, 0, 1) ne "\""));
    if ($code eq "") { errore "stringa non terminata."; };
    $res=$res. "\"";
    $code=substr($code, 1);
