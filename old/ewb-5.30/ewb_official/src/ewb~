  $res.="\$EWB_forblockvar".$nc."=substr(\$EWB_forblockvar".$nc.", index(\$EWB_forblockvar".$nc.", \" \")+1);$T";


  if (substr($code,0,1) ne "{") { errore "Necessaria \"{\" dopo foreach. "; }
  $code=substr($code, 1);
