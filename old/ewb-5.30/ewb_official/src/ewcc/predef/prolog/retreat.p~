sub PD_retreat($)
{ my $code=$_[0];
  my $res="";
  my $rcd;($code,$rcd)=delperc($code);$res.=$rcd;;
  ($code,$a)=variable($code);
  my $hp;
  $res.= "";#"(EWretract(";
  if (substr($code, 0,1) eq "(")
  { ($code,$rcd)=delperc(substr($code, 1));
    $hp=1;
  }
#qui una variabile anziche' il codice.
  ($code, $a)=variable($code);
  checkpredef($a);
  #$res.= "\"".$a."\"";
  my $rcd;($code,$rcd)=delperc($code);$res.=$rcd;;
  if ((substr($code, 0, 1) ne ","))
  { errore "retract - manca un parametro.";
  }
  ($code,$rcd)=delperc(substr($code,1));

  my $rb;
  ($code,$rb)=(calcexp($code));
  $res=$res.$rb;
  my $rcd;($code,$rcd)=delperc($code);$res.=$rcd;;
  $res.="\$ax=EWretract(\"$a\",\$ax);$T";

  if (($hp) && (substr($code, 0, 1) ne ")"))
  { errore "retract - parentesi non chiusa.";
  }
  if ($hp) { ($code,$rcd)=delperc(substr($code, 1)); }
  $res.= "))";
  return ($code, $res);
}
