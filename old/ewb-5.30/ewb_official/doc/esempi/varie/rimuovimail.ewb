'rimozione di un utente per posta. 
#include "tabelle.inc"

var a,b; b="invia"; 

var r; 
r="Nessuno";

in (referenti)
{ r=r.";".nomecogn;
};
nomecogn=r; 
r="eliminazione utente di posta"; 
ask r:info, user, b:submit; 


if (!(exist(accessi)))
{ show "account inesistente";
  end ; 
};
lock accessi; 
lock personale; 
a=user; 
remove(accessi);
in (personale, a eq user)
{ user="";
  add(personale); 
}; 

unlock accessi;
unlock personale; 
show "Rimosso utente di posta."; 
